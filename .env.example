# Copiez ce fichier vers .env et renseignez vos propres valeurs.
# Ne jamais commiter le fichier .env réel (secrets).

# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── NEXTAUTH ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── STRIPE ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── EMAIL ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=
ADMIN_EMAIL=
EMAIL_FROM="LME Occasions <onboarding@resend.dev>"

# ─── PUSHER (Real-time) ───────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ─── CLOUDINARY (Image Upload + Factures PDF) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── APP SETTINGS ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LME Occasions
DEPOSIT_PERCENTAGE=30
RESERVATION_EXPIRY_DAYS=5
MAINTENANCE_MODE=false

# ─── VERCEL CRON ─────────────────────────────────────────────────────────────
CRON_SECRET=

# ─── FACTURATION (optionnel) ──────────────────────────────────────────────────
COMPANY_NAME=LME Occasions
COMPANY_TAGLINE="Véhicules d'occasion premium"
COMPANY_ADDRESS_LINE1=
COMPANY_ADDRESS_LINE2=
COMPANY_EMAIL=
COMPANY_PHONE=
COMPANY_SIRET=
INVOICE_LEGAL_MENTION=
INVOICE_VAT_RATE=8.5